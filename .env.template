# Copy this file to `.env` (gitignored) and fill in values before running any script.
#
# SECURITY: treat every key in this file as a secret.  Rotate any key that
# has been pasted into chat, email, or any untrusted surface immediately at:
#   Azure portal  -> your resource -> Keys and Endpoint  (for AZURE_AI_API_KEY)
#   console.x.ai  -> API Keys                             (for XAI_API_KEY)
# Never commit a filled-in .env; the .gitignore already excludes it.
#
# Used by: ncot_divergence_pilot.ipynb, run_debate_std_cot_ablation.py,
#          run_phase_c.py, and all scripts under scripts/.

# --- Azure Foundry endpoint (covers OpenAI-on-Foundry AND Anthropic-on-Foundry) ---
AZURE_AI_PROJECT_ENDPOINT="https://<resource>.cognitiveservices.azure.com"
AZURE_AI_API_KEY="<your-azure-foundry-key>"
AZURE_AI_API_VERSION="2025-04-01-preview"

# --- Generator model list (comma-separated; used by run_debate_std_cot_ablation.py) ---
AZURE_AI_MODELS_GENERATION="gpt-5.4-nano,gpt-4o"

# --- xAI (Grok) key -- only needed for grok-4-1-fast-reasoning ---
XAI_API_KEY="<your-xai-key>"

# --- Judge / extractor models (notebook and scripts) ---
AZURE_AI_MODEL_JUDGE="claude-sonnet-4-6"
AZURE_AI_MODEL_JUDGE_2="gpt-4o-mini"
AZURE_AI_MODEL_DECISION="gpt-4o-mini"

# --- Optional Anthropic endpoint override ---
# Defaults to {AZURE_AI_PROJECT_ENDPOINT}/anthropic/v1/messages
# ANTHROPIC_ENDPOINT="https://..."
